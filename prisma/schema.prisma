// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
  generateClientTypes = true
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String

  bio          String?  @db.Text
  avatarUrl    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  posts        Post[]
  comments     Comment[]
  reactions    Reaction[]

  // Watching system
  watching     Watch[] @relation("Watcher")
  watchers     Watch[] @relation("Watching")

  // Messaging
  messages     Message[]
  participants ConversationParticipant[]

  // Pictures and videos uploaded by the user
  media        Media[] 

  @@index([username])
}

//////////////////////////////////////////////////
// WATCHING (FOLLOW SYSTEM)
//////////////////////////////////////////////////

model Watch {
  id           String   @id @default(cuid())

  watcherId    String
  watchingId   String

  createdAt    DateTime @default(now())

  watcher      User @relation("Watcher", fields: [watcherId], references: [id], onDelete: Cascade)
  watching     User @relation("Watching", fields: [watchingId], references: [id], onDelete: Cascade)

  @@unique([watcherId, watchingId]) // prevent duplicates
  @@index([watchingId])
  @@index([watcherId])
}

//////////////////////////////////////////////////
// POSTS
//////////////////////////////////////////////////

model Post {
  id          String   @id @default(cuid())
  authorId    String

  content     String   @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  comments    Comment[]
  reactions   Reaction[]
  media       Media[]   // 🔥 NEW

  @@index([authorId, createdAt])
}

enum MediaType {
  IMAGE
  VIDEO
}

model Media {
  id          String   @id @default(cuid())

  url         String
  thumbnailUrl String? 

  type        MediaType
  mimeType    String
  size        Int

  width       Int?
  height      Int?
  duration    Int?     // seconds (video)

  createdAt   DateTime @default(now())

  // Relations
  postId      String?
  messageId   String?

  uploaderId  String

  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  message     Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader    User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([messageId])
  @@index([uploaderId])
}

//////////////////////////////////////////////////
// COMMENTS
//////////////////////////////////////////////////

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String

  // Long-form support
  content   String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  reactions Reaction[]

  @@index([postId, createdAt])
}

//////////////////////////////////////////////////
// REACTIONS (LIKES, ETC)
//////////////////////////////////////////////////

model Reaction {
  id        String   @id @default(cuid())

  userId    String
  postId    String?
  commentId String?

  type      ReactionType

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])

  @@index([postId])
  @@index([commentId])
  @@index([userId])
}

enum ReactionType {
  LIKE
  LOVE
  LAUGH
  ANGRY
}

//////////////////////////////////////////////////
// MESSAGING
//////////////////////////////////////////////////

model Conversation {
  id          String   @id @default(cuid())
  isGroup     Boolean  @default(false)
  title       String?

  createdAt   DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]

  @@index([createdAt])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String

  lastReadAt     DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String

  content        String   @db.Text

  createdAt      DateTime @default(now())
  media          Media[]

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}


model Translation {
  id       String    @id @default(cuid())
  code     String    @unique
  name     String
  books    Book[]
  chapters Chapter[]
  verses   Verse[]
}

model Book {
  id           String      @id @default(cuid())
  name         String
  chapterCount Int

  translationCode String
  translation     Translation @relation(fields: [translationCode], references: [code])

  chapters Chapter[]
  verses   Verse[]
}

model Chapter {
  id         String @id @default(cuid())
  number     Int
  verseCount Int

  translationCode String
  translation     Translation @relation(fields: [translationCode], references: [code])

  bookId String
  book   Book   @relation(fields: [bookId], references: [id])

  verses Verse[]
}

model Verse {
  id     String @id @default(cuid())
  number Int
  text   String @db.Text

  translationCode String
  translation     Translation @relation(fields: [translationCode], references: [code])

  bookId String
  book   Book @relation(fields: [bookId], references: [id])

  chapterNumber Int
  chapterId     String
  chapter       Chapter @relation(fields: [chapterId], references: [id])
}