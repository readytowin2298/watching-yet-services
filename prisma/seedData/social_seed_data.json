  "Post": [
    {
      "id": "post_1",
      "authorId": "usr_alex",
      "content": "Just shipped a redesign of my notes app. The big win was cutting three clicks from the happy path.",
      "mediaUrl": "https://picsum.photos/seed/post1/1200/800",
      "mediaType": "IMAGE",
      "createdAt": "2026-03-24T02:10:00Z",
      "updatedAt": "2026-03-24T02:10:00Z"
    },
    {
      "id": "post_2",
      "authorId": "usr_bri",
      "content": "Built a small feed ranking prototype today. Next step: measure how often people scroll past the first card.",
      "mediaUrl": null,
      "mediaType": null,
      "createdAt": "2026-03-25T04:10:00Z",
      "updatedAt": "2026-03-25T04:10:00Z"
    },
    {
      "id": "post_3",
      "authorId": "usr_cam",
      "content": "Sharing a sunset shot from the river trail. Planning to turn these weekend photos into a weekly gallery.",
      "mediaUrl": "https://picsum.photos/seed/post3/1200/800",
      "mediaType": "IMAGE",
      "createdAt": "2026-03-26T01:10:00Z",
      "updatedAt": "2026-03-26T01:10:00Z"
    },
    {
      "id": "post_4",
      "authorId": "usr_dan",
      "content": "Trying a new message composer layout. Auto-saving drafts made a huge difference in testing.",
      "mediaUrl": null,
      "mediaType": null,
      "createdAt": "2026-03-27T05:10:00Z",
      "updatedAt": "2026-03-27T05:10:00Z"
    },
    {
      "id": "post_5",
      "authorId": "usr_emi",
      "content": "Wrote about building in public without oversharing. There is a sweet spot between honesty and polish.",
      "mediaUrl": null,
      "mediaType": null,
      "createdAt": "2026-03-28T03:10:00Z",
      "updatedAt": "2026-03-28T03:10:00Z"
    },
    {
      "id": "post_6",
      "authorId": "usr_fox",
      "content": "Prototype of a group chat sidebar with presence indicators. Tiny details make the whole thing feel alive.",
      "mediaUrl": "https://picsum.photos/seed/post6/1200/800",
      "mediaType": "IMAGE",
      "createdAt": "2026-03-29T02:10:00Z",
      "updatedAt": "2026-03-29T02:10:00Z"
    },
    {
      "id": "post_7",
      "authorId": "usr_alex",
      "content": "Spent the afternoon tuning onboarding copy. Shorter sentences performed better in the last usability test.",
      "mediaUrl": null,
      "mediaType": null,
      "createdAt": "2026-03-30T04:10:00Z",
      "updatedAt": "2026-03-30T04:10:00Z"
    },
    {
      "id": "post_8",
      "authorId": "usr_bri",
      "content": "Added a dark mode toggle and tested it on a low-power phone. Battery impact was basically negligible.",
      "mediaUrl": null,
      "mediaType": null,
      "createdAt": "2026-03-31T06:10:00Z",
      "updatedAt": "2026-03-31T06:10:00Z"
    }
  ],
  "Comment": [
    {
      "id": "cmt_1",
      "postId": "post_1",
      "authorId": "usr_bri",
      "content": "Love the cleaner flow. What did you use to measure the drop in clicks?",
      "createdAt": "2026-03-25T01:10:00Z",
      "updatedAt": "2026-03-25T01:10:00Z"
    },
    {
      "id": "cmt_2",
      "postId": "post_1",
      "authorId": "usr_emi",
      "content": "The spacing and contrast look much better now.",
      "createdAt": "2026-03-25T02:10:00Z",
      "updatedAt": "2026-03-25T02:10:00Z"
    },
    {
      "id": "cmt_3",
      "postId": "post_2",
      "authorId": "usr_alex",
      "content": "Would love to see how this behaves with a larger sample size.",
