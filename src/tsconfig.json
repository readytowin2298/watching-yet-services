{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",             // New in TS 6: keeps your imports exactly as written
    "moduleResolution": "bundler",    // Stops the 'node10' deprecation error
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@generated/*": ["./src/generated/*"]
    }
  },
  "include": ["../src/**/*"],
  "exclude": ["node_modules"]
}