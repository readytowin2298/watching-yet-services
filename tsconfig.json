{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@generated/*": ["./src/generated/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "extraSeed"]
}